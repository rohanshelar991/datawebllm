# gitignore template for LangChain products, e.g., LangGraph, LangSmith
# website: https://www.langchain.com/
# website: https://www.langchain.com/langgraph

# LangGraph
.langgraph_api/

# Secrets
.env
.env.*
!.env.example

# Python
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/

# Node
node_modules/

# Streamlit (keep config tracked)
.streamlit/
!.streamlit/
!.streamlit/config.toml
!.streamlit/secrets.toml.example
.streamlit/secrets.toml

# Data artifacts
*.png
*.duckdb
.DS_Store
frontend/dist/
backend/storage/*
!backend/storage/.gitkeep
!backend/storage/datasets/
backend/storage/datasets/*
!backend/storage/datasets/.gitkeep
